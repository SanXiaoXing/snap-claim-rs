{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SnapClaim",
  "version": "1.2.3",
  "identifier": "cn.sanxiaoxing.snap-claim",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SnapClaim",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "SanXiaoXing",
    "copyright": "Copyright © 2026 SanXiaoXing. All rights reserved.",
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/pdfium.dll": "resources/pdfium.dll"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/SanXiaoXing/snap-claim-rs/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNBRjk2REFENUUxNzZFQzQKUldURWJoZGVyVzM1T2xjS0dETHE5dURBc29JZ0xyS0pNSVlQRHEydnNhOXlYT3FYazRlR3JaS0YK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}